# TasteLocal Environment Configuration
# Copy this to .env and fill in your values

SECRET_KEY=your-secret-key-change-in-production-django-insecure-abc123xyz
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# MySQL Database
DB_NAME=tastelocal_db
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_HOST=127.0.0.1
DB_PORT=3306

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=tastelocal2@gmail.com
EMAIL_HOST_PASSWORD=your_app_password_here
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=TasteLocal <tastelocal2@gmail.com>

# Google Maps API Key
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
